# This file was created with the 7i96 Wizard on Jun 10 2019 11:12:47
# Changes to most things are ok and will be read by the wizard

[EMC]
VERSION = 1.1
MACHINE = MACINATOR
DEBUG = 0x00000000

[DISPLAY]
DISPLAY = axis
PREFERENCE_FILE_PATH = WORKINGFOLDER/qtdragon.pref
POSITION_OFFSET = RELATIVE
POSITION_FEEDBACK = ACTUAL
GRIDS = 10mm 20mm 50mm 100mm 
MAX_FEED_OVERRIDE       = 2
MAX_RAPID_OVERRIDE      = 2
MIN_SPINDLE_0_OVERRIDE    = 0.5
MAX_SPINDLE_0_OVERRIDE    = 1.5
DEFAULT_SPINDLE_0_SPEED = 12000
SPINDLE_INCREMENT = 200
MIN_SPINDLE_0_SPEED = 5000
MAX_SPINDLE_0_SPEED = 25000
MIN_SPINDLE_0_OVERRIDE =  0.5
MAX_SPINDLE_0_OVERRIDE =  1.5
# linear
MIN_LINEAR_VELOCITY     = 0
MAX_LINEAR_VELOCITY     = 75.00
DEFAULT_LINEAR_VELOCITY = 33.33
# jog
DEFAULT_LINEAR_JOG_VEL  = 25.0
# angular
MIN_ANGULAR_VELOCITY = 0
MAX_ANGULAR_VELOCITY = 50
DEFAULT_ANGULAR_VELOCITY = 25
CYCLE_TIME = 100
INTRO_GRAPHIC = linuxcnc.gif
INTRO_TIME = 2
PROGRAM_PREFIX = /home/andrea/Dropbox/GCODE/
INCREMENTS = 5 mm, 1.0 mm, 0.10 mm, 0.01 mm
ANGULAR_INCREMENTS = 1, 5, 10, 30, 45, 90, 180, 360
MDI_HISTORY_FILE = mdi_history.dat
MACHINE_LOG_PATH = machine_log.dat
LOG_FILE = qtdragon.log
TOOL_EDITOR = tooledit
CONFIRM_EXIT = True
#embedded vpc panels
#EMBED_TAB_NAME = NCam
#EMBED_TAB_COMMAND = ncam
#EMBED_TAB_LOCATION = stackedWidget_mainTab

[FILTER]
PROGRAM_EXTENSION = .ngc,.nc,.tap G-Code File (*.ngc,*.nc,*.tap)
PROGRAM_EXTENSION = .png,.gif,.jpg Greyscale Depth Image
PROGRAM_EXTENSION = .py Python Script
png = image-to-gcode
gif = image-to-gcode
jpg = image-to-gcode
py = python

[KINS]
KINEMATICS = trivkins coordinates=XYZ
JOINTS = 3

[EMCIO]
EMCIO = io
CYCLE_TIME = 0.100
TOOL_TABLE = /home/andrea/linuxcnc/QTDragon/tool.tbl
TOOL_CHANGE_POSITION = 189.5 10 0
TOOL_CHANGE_QUILL_UP = 1

[RS274NGC]
PARAMETER_FILE = qtdragon.var
RS274NGC_STARTUP_CODE = G17 G21 G40 G43H0 G54 G64P0.005 G80 G90 G94 G97 M5 M9
SUBROUTINE_PATH = /home/andrea/linuxcnc/nc_files/probe/basic_probe/macros:/home/andrea/nativecam/my-stuff:/home/andrea/nativecam/lib/mill:/home/andrea/nativecam/lib/utilities
USER_M_PATH = /home/andrea/nativecam/scripts/m_codes
FEATURES=12
#REMAP=M6   modalgroup=6  prolog=change_prolog   ngc=manual_change  epilog=change_epilog

[EMCMOT]
EMCMOT = motmod
SERVO_PERIOD = 1000000
COMM_TIMEOUT = 1.0
COMM_WAIT = 0.010
BASE_PERIOD = 20000
#PINS BASE CLOCK GENERATION AND SETRAJECTORY TO A ISOLATED CPU. ISOLATINGCPU DONE IN GRUB CONFIG
BASE_CPU = 3
SERVO_CPU = 3
#NUM_AIO = 12

[TASK]
TASK = milltask
CYCLE_TIME = 0.001

[TRAJ]
COORDINATES = XYZ
LINEAR_UNITS = metric
ANGULAR_UNITS = degree
MAX_LINEAR_VELOCITY = 66.67
DEFAULT_LINEAR_VELOCITY = 33.33
SPINDLES = 1
POSITION_FILE = position.txt
NO_FORCE_HOMING = 1

[HAL]
HALUI = halui
#HALFILE = core_sim.hal
HALFILE = qtdragonMac.hal
#HALFILE = qtdragon.hal
HALFILE = custom.hal
POSTGUI_HALFILE = qtdragon_postgui.hal

[HALUI]
# no content

[TOOLSENSOR]
